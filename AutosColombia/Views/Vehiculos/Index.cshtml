@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Gestión de Vehículos</title>

    <style>
        body{
            margin:0;
            font-family: Arial;
            background-image: url('/Imagenes/Fondo.jpg');
            background-size: cover;
            background-position:center;
        }

        .capa{
            background: rgba(0,0,0,0.6);
            min-height:100vh;
            padding:30px;
        }

        .caja{
            background: rgba(255,255,255,0.92);
            padding:20px;
            max-width:1000px;
            margin:auto;
            border-radius:10px;
        }

        input, select{
            width:100%;
            padding:6px;
            margin-bottom:10px;
        }

        .fila-botones{
            display:flex;
            gap:10px;
            flex-wrap:wrap;
            margin-top:8px;
            align-items:center;
        }

        button, a{
            padding:8px 12px;
            color:white;
            border:none;
            text-decoration:none;
            border-radius:5px;
            cursor:pointer;
        }

        .guardar{ background:#2ecc71; }
        .cancelar{ background:#95a5a6; }
        .parqueo{ background:#3498db; }
        .celdas{ background:#8e44ad; }
        .logout{ background:#e74c3c; margin-left:auto; }

        table{
            width:100%;
            border-collapse: collapse;
            margin-top:20px;
        }

        th, td{
            border:1px solid #ccc;
            padding:8px;
            text-align:center;
        }

        th{ background:#eee; }

        .acciones button{
            padding:6px 10px;
            border-radius:5px;
        }
        .acciones .edit{ background:#f39c12; }
        .acciones .del{ background:#e74c3c; }
    </style>
</head>

<body>
<div class="capa">
<div class="caja">

    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
        <h2 style="margin:0;">Gestión de Vehículos</h2>
        <a class="parqueo" asp-controller="Parqueo" asp-action="Index">Ir a Registro de Parqueo</a>
        <a class="celdas" asp-controller="Celdas" asp-action="Index">Ir a Celdas</a>
        <a class="logout" asp-controller="Login" asp-action="Salir">Cerrar sesión</a>
    </div>

    <form id="formVehiculo" onsubmit="return false;">
        <input type="hidden" id="modoEdicion" value="">

        <label>Placa</label>
        <input type="text" id="placa" placeholder="Ej: ABC123" required>

        <label>Tipo de vehículo</label>
        <select id="tipo" required>
            <option value="">-- Seleccione --</option>
            <option>Carro</option>
            <option>Moto</option>
            <option>Camioneta</option>
            <option>Camión</option>
            <option>Otro</option>
        </select>

        <label>Marca</label>
        <input type="text" id="marca" placeholder="Ej: Mazda" required>

        <label>Color</label>
        <input type="text" id="color" placeholder="Ej: Rojo" required>

        <div class="fila-botones">
            <button type="button" class="guardar" onclick="guardarVehiculo()">Guardar</button>
            <button type="button" class="cancelar" onclick="cancelarEdicion()">Cancelar</button>
        </div>

        <small style="display:block; margin-top:8px; color:#333;">
            * Esta pantalla es solo para <b>registrar los vehículos</b>. El parqueo (entrada/salida/celda) se maneja en <b>Registro de Parqueo</b>.
        </small>
    </form>

    <table id="tabla">
        <thead>
            <tr>
                <th>Placa</th>
                <th>Tipo</th>
                <th>Marca</th>
                <th>Color</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>

</div>
</div>

<script>
const KEY_VEHICULOS = "autoscolombia_vehiculos_catalogo";
const KEY_PARQUEOS  = "autoscolombia_parqueos";

function getJson(key){
    try{ return JSON.parse(localStorage.getItem(key) || "[]"); }
    catch(e){ return []; }
}
function setJson(key, value){
    localStorage.setItem(key, JSON.stringify(value));
}

function normalizarPlaca(placa){
    return (placa || "").trim().toUpperCase();
}

function hayParqueoActivo(placa){
    const parqueos = getJson(KEY_PARQUEOS);
    const p = parqueos.find(x => (x.placa || "") === placa && !(x.salida && x.salida.trim() !== ""));
    return !!p;
}

function cargarTabla(){
    const vehiculos = getJson(KEY_VEHICULOS);
    const tbody = document.querySelector("#tabla tbody");
    tbody.innerHTML = "";

    vehiculos.forEach(v => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
            <td>${v.placa}</td>
            <td>${v.tipo}</td>
            <td>${v.marca}</td>
            <td>${v.color}</td>
            <td class="acciones">
                <button class="edit" type="button" onclick="editarVehiculo('${v.placa}')">Editar</button>
                <button class="del" type="button" onclick="eliminarVehiculo('${v.placa}')">Eliminar</button>
            </td>
        `;
        tbody.appendChild(tr);
    });
}

function guardarVehiculo(){
    const placa = normalizarPlaca(document.getElementById("placa").value);
    const tipo  = (document.getElementById("tipo").value || "").trim();
    const marca = (document.getElementById("marca").value || "").trim();
    const color = (document.getElementById("color").value || "").trim();
    const modo  = document.getElementById("modoEdicion").value; // "" o placa

    if(!placa || !tipo || !marca || !color){
        alert("Complete todos los campos.");
        return;
    }

    let vehiculos = getJson(KEY_VEHICULOS);
    const existe = vehiculos.some(v => v.placa === placa);

    if(modo === ""){
        if(existe){
            alert("Esa placa ya está registrada.");
            return;
        }
        vehiculos.push({ placa, tipo, marca, color });
    }else{
        const placaOriginal = modo;

        // si cambió la placa, validar duplicado
        if(placa !== placaOriginal && existe){
            alert("No puedes cambiar la placa a una que ya exista.");
            return;
        }

        // Si el vehículo tiene un parqueo activo, no permitir cambiar la placa (para no romper la salida)
        if(placa !== placaOriginal && hayParqueoActivo(placaOriginal)){
            alert("No puedes cambiar la placa porque ese vehículo tiene un parqueo activo (sin salida).");
            return;
        }

        vehiculos = vehiculos.map(v => v.placa === placaOriginal ? { placa, tipo, marca, color } : v);
        setJson(KEY_VEHICULOS, vehiculos);

        // si cambió la placa, actualizar parqueos históricos
        if(placa !== placaOriginal){
            let parqueos = getJson(KEY_PARQUEOS);
            parqueos = parqueos.map(p => (p.placa || "") === placaOriginal ? { ...p, placa } : p);
            setJson(KEY_PARQUEOS, parqueos);
        }
    }

    setJson(KEY_VEHICULOS, vehiculos);
    cancelarEdicion();
    cargarTabla();
}

function editarVehiculo(placa){
    const vehiculos = getJson(KEY_VEHICULOS);
    const v = vehiculos.find(x => x.placa === placa);
    if(!v) return;

    document.getElementById("placa").value = v.placa;
    document.getElementById("tipo").value  = v.tipo;
    document.getElementById("marca").value = v.marca;
    document.getElementById("color").value = v.color;
    document.getElementById("modoEdicion").value = v.placa;
}

function eliminarVehiculo(placa){
    placa = normalizarPlaca(placa);
    if(hayParqueoActivo(placa)){
        alert("No puedes eliminar este vehículo porque tiene un parqueo activo (sin salida).");
        return;
    }

    if(!confirm("¿Seguro que deseas eliminar el vehículo " + placa + "?")) return;
    let vehiculos = getJson(KEY_VEHICULOS);
    vehiculos = vehiculos.filter(v => v.placa !== placa);
    setJson(KEY_VEHICULOS, vehiculos);
    cancelarEdicion();
    cargarTabla();
}

function cancelarEdicion(){
    document.getElementById("modoEdicion").value = "";
    document.getElementById("formVehiculo").reset();
}

cargarTabla();
</script>

</body>
</html>
